extends ../../layouts/default.pug
include ../../mixins/alert.pug

block css
  link(rel="stylesheet" href="/client/css/cart.css")

block main
  +alert-success(3000)
  +alert-unsuccess(3000)

  .cart-page
    a.cart-back(href="/products")
      svg(xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor")
        path(stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7")
      | Tiếp tục mua sắm

    .cart-header
      h1 Giỏ hàng của bạn
      if cartDetail && cartDetail.products.length > 0
        p #{cartDetail.products.length} sản phẩm trong giỏ hàng
      else
        p Giỏ hàng đang trống

    if !cartDetail || cartDetail.products.length === 0
      .cart-empty
        svg(xmlns="http://www.w3.org/2000/svg" width="64" height="64" fill="none" viewBox="0 0 24 24" stroke="currentColor")
          path(stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z")
        p Giỏ hàng của bạn đang trống 🛒
        a.btn-checkout(href="/products") Khám phá sản phẩm

    else
      form.cart-layout(action="/checkout/payment-info" method="POST" id="cartFormCheckout")
        input(type="hidden" name="_csrf" value=csrfToken)
        .cart-items-wrap
          .cart-list-header
            input.select-all-checkbox(type="checkbox" id="selectAll")
            label(for="selectAll") Chọn tất cả
            span.header-label Sản phẩm

          .cart-items-list
            each item in cartDetail.products
              .cart-item(data-id=item.product_id + (item.variant_id ? `_${item.variant_id}` : '') data-item-total=item.totalPrice)
                .cart-item-select
                  input.item-checkbox(
                    type="checkbox"
                    name="cartItemIds"
                    value=item.product_id + (item.variant_id ? `_${item.variant_id}` : '')
                  )

                button.cart-item-remove(
                  type="button"
                  title="Xóa sản phẩm"
                  data-product-id=item.product_id
                  data-variant-id=item.variant_id
                )
                  svg(xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor")
                    path(stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12")

                .cart-item-img
                  if item.productInfo
                    img(
                      src=item.thumbnail
                      alt=item.productInfo.title
                    )
                  else
                    img(src="/images/no-image.jpg" alt="No Image")

                .cart-item-info
                  if item.productInfo
                    span.cart-item-brand= item.productInfo.brand || 'TIDA'
                    h3.cart-item-name= item.productInfo.title
                    p.cart-item-variant= item.variantDisplay || ''
                  else
                    h3.cart-item-name Sản phẩm không khả dụng

                .cart-item-qty
                  button.qty-btn.qty-minus(
                    type="button"
                    data-product-id=item.product_id
                    data-variant-id=item.variant_id
                  )
                    svg(xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor")
                      path(stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M20 12H4")
                  span.qty-value= item.quantity
                  button.qty-btn.qty-plus(
                    type="button"
                    data-product-id=item.product_id
                    data-variant-id=item.variant_id
                  )
                    svg(xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor")
                      path(stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 4v16m8-8H4")

                .cart-item-price
                  span.price-new #{item.priceNew.toLocaleString('vi-VN')} ₫
                  span.price-total(data-item-total=item.totalPrice) #{item.totalPrice.toLocaleString('vi-VN')} ₫

        .cart-summary
          h2.summary-title Tóm tắt đơn hàng

          .summary-coupon
            label.coupon-label MÃ GIẢM GIÁ
            .coupon-input-wrap
              input.coupon-input(
                type="text"
                placeholder="Nhập mã"
                name="couponCode"
              )
              button.coupon-btn(type="button")
                svg(xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor")
                  path(stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z")
                | Áp dụng

          .summary-rows
            .summary-row
              span Tạm tính
              span#subtotal 0 ₫

            .summary-row
              span Phí vận chuyển
              span.free Miễn phí

          .summary-divider

          .summary-total
            span Tổng cộng
            span#finalTotal 0 ₫

          button.btn-checkout(type="submit" disabled)
            svg(xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor")
              path(stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z")
            | Thanh toán

      .cart-related
        h2.related-title Có thể bạn quan tâm
        if suggestedProducts && suggestedProducts.length > 0
          .related-grid
            each product in suggestedProducts
              a.related-card(href=`/products/detail/${product._id}`)
                .related-img
                  img(src=(product.thumbnail || "/images/no-image.jpg") alt=product.title)
                .related-info
                  span.related-brand= product.brand
                  h3.related-name= product.title
                  .related-price
                    span= Number(product.priceNew || 0).toLocaleString('vi-VN') + ' ₫'
                    button.related-add(type="button" aria-label=`Xem ${product.title}`)
                      svg(xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor")
                        path(stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 4v16m8-8H4")

  script(src="/client/js/cart.js")
