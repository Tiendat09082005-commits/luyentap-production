extends ../../layouts/default.pug
include ../../mixins/alert.pug

block css
  link(rel="stylesheet" href="/client/css/detailUser.css")

block main
  +alert-success(5000)
  +alert-unsuccess(5000)

  .user-detail-container
    //- ===== PAGE HEADER =====
    .user-page-header
      h1 Tài khoản của bạn
      p Quản lý thông tin cá nhân, địa chỉ giao hàng và lịch sử mua hàng

    .user-detail-layout
      //- ===== LEFT SIDEBAR =====
      .user-sidebar
        nav.user-nav
          a.user-nav-item.active(href="#profile" data-tab="profile")
            svg(xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor")
              path(stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z")
            | Hồ sơ cá nhân
          a.user-nav-item(href="#address" data-tab="address")
            svg(xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor")
              path(stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z")
              path(stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z")
            | Địa chỉ giao hàng
          a.user-nav-item(href="#orders" data-tab="orders")
            svg(xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor")
              path(stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z")
            | Lịch sử đơn hàng
          .user-nav-divider
          .nav-settings Cài đặt
          form(action="/user/logout" method="POST")
            input(type="hidden" name="_csrf" value=csrfToken)
            button.user-nav-item.nav-logout(type="submit")
              svg(xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor")
                path(stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1")
              | Đăng xuất

      //- ===== RIGHT CONTENT =====
      .user-content
        //- TAB 1: HỒ SƠ CÁ NHÂN
        .user-tab.active#tab-profile
          .tab-header
            div
              h2 Thông tin cá nhân
              p Cập nhật chi tiết tài khoản của bạn
            button.btn-edit#btn-open-edit(type="button")
              svg(xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor")
                path(stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z")
              | Chỉnh sửa

          .info-grid
            .info-card
              span.info-card-label HỌ VÀ TÊN
              .info-card-value= user.fullName

            .info-card
              span.info-card-label EMAIL
              .info-card-value
                svg(xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor")
                  path(stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z")
                span= user.email

          .info-grid.info-grid-full
            .info-card
              span.info-card-label SỐ ĐIỆN THOẠI
              .info-card-value
                svg(xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor")
                  path(stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z")
                span= user.phone || 'Chưa cập nhật'

        //- TAB 2: ĐỊA CHỈ GIAO HÀNG
        .user-tab#tab-address
          .tab-header
            div
              h2 Địa chỉ giao hàng
              p Quản lý địa chỉ giao hàng của bạn
            button.btn-edit#btn-open-edit-address(type="button")
              svg(xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor")
                path(stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z")
              | Chỉnh sửa

          .address-card
            .address-card-header
              svg(xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor")
                path(stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z")
                path(stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z")
              div
                span.address-badge ĐỊA CHỈ CHÍNH
                if user.address || user.wardName || user.districtName || user.provinceName
                  p.address-main
                    if user.address
                      | #{user.address}, 
                    if user.wardName
                      | #{user.wardName}, 
                    if user.districtName
                      | #{user.districtName}, 
                    if user.provinceName
                      | #{user.provinceName}
                else
                  p.address-main Chưa cập nhật địa chỉ

            .address-meta
              .address-meta-item
                span.address-meta-label PHƯỜNG / XÃ
                span.address-meta-value= user.wardName || '---'
              .address-meta-item
                span.address-meta-label QUẬN / HUYỆN
                span.address-meta-value= user.districtName || '---'
              .address-meta-item
                span.address-meta-label TỈNH / THÀNH PHỐ
                span.address-meta-value= user.provinceName || '---'

        //- TAB 3: LỊCH SỬ ĐƠN HÀNG
        .user-tab#tab-orders
          .tab-header
            div
              h2 Lịch sử đơn hàng
              p Xem chi tiết các đơn hàng của bạn

          if orders && orders.length
            each order in orders
              a.order-card(href=`/orders/${order.id}` class=order.statusClass)
                .order-card-left
                  .order-icon
                    svg(xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor")
                      path(stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4")
                  div
                    span.order-code= order.orderCode
                    span.order-date= new Date(order.createdAt).toLocaleDateString('vi-VN', { day: 'numeric', month: 'long', year: 'numeric' })
                    .order-products-preview
                      each product, index in order.products
                        span.product-name= product.title
                        if index < order.products.length - 1
                          span.product-separator •
                .order-card-meta
                  .order-meta-item
                    span.order-meta-label Số  sản phẩm
                    span.order-meta-value= order.itemCount
                  .order-meta-item
                    span.order-meta-label Tổng tiền
                    span.order-meta-value.order-total= (order.totalPrice || 0).toLocaleString('vi-VN') + ' ₫'
                  .order-meta-item
                    span.order-meta-label Trạng thái
                    span.order-status(class=order.statusClass)= order.statusText
                svg.order-arrow(xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor")
                  path(stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7")
          else
            .order-card
              .order-icon
                svg(xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor")
                  path(stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4")
              p Chưa có đơn hàng nào

    //- ===== EDIT MODAL =====
    .user-modal#edit-profile-modal
      .modal-overlay
      .modal-content
        .modal-header
          div
            h3 Chỉnh sửa thông tin
            p Cập nhật thông tin cá nhân của bạn
          button.modal-close(type="button") &times;

        form(action="/user/edit" method="POST")
          input(type="hidden" name="_csrf" value=csrfToken)
          .modal-body
            .form-section
              h4 Thông tin cơ bản
              .form-row
                .form-group
                  label(for="fullName") Họ và tên
                  input#fullName(type="text" name="fullName" value=user.fullName required)
                .form-group
                  label(for="phone") Số điện thoại
                  input#phone(type="text" name="phone" value=user.phone)

            .form-section
              h4 Địa chỉ giao hàng
              .form-row
                .form-group
                  label TỈNH / THÀNH PHỐ
                  select.form-select(name="province" required button-province data-current=user.provinceCode)
                    option(value="" disabled selected) Đang tải...
                .form-group
                  label QUẬN / HUYỆN
                  select.form-select(name="district" required button-district)
                    option(value="" disabled selected) Chọn tỉnh trước
              .form-row
                .form-group
                  label PHƯỜNG / XÃ
                  select.form-select(name="ward" required button-ward)
                    option(value="" disabled selected) Chọn huyện trước
                .form-group
                  label(for="address") SỐ NHÀ / TÊN ĐƯỜNG
                  input#address(type="text" name="address" value=user.address placeholder="Ví dụ: 123 Nguyễn Huệ" required)

            .form-section.password-section
              h4 Xác nhận cập nhật
              p Vui lòng nhập mật khẩu hiện tại để lưu thay đổi
              .form-group
                label(for="currentPassword") Mật khẩu hiện tại
                input#currentPassword(
                  type="password"
                  name="currentPassword"
                  required
                  autocomplete="new-password"
                  readonly
                  onfocus="this.removeAttribute('readonly');"
                  placeholder="Nhập mật khẩu của bạn"
                )

          .modal-footer
            button.btn-cancel.modal-close(type="button") Hủy bỏ
            button.btn-save(type="submit") Lưu thay đổi

    //- ===== ACTION BUTTONS (giữ class cũ) =====
    .action-buttons.hidden
      a.btn-custom.btn-back(href="/users")
        i.fas.fa-arrow-left
        span Quay lại
      a.btn-custom.btn-edit(href=`/users/edit/${user.id}`)
        i.fas.fa-edit
        span Chỉnh sửa
      a.btn-custom.btn-delete(href=`/users/delete/${user.id}` onclick="return confirm('Bạn có chắc chắn muốn xóa?')")
        i.fas.fa-trash-alt
        span Xóa

  script.
    // Tab switching
    var navItems = document.querySelectorAll('.user-nav-item[data-tab]');
    var tabs = document.querySelectorAll('.user-tab');

    navItems.forEach(function(item) {
      item.addEventListener('click', function(e) {
        e.preventDefault();
        var tab = this.dataset.tab;

        navItems.forEach(function(i) { i.classList.remove('active'); });
        tabs.forEach(function(t) { t.classList.remove('active'); });

        this.classList.add('active');
        document.getElementById('tab-' + tab).classList.add('active');
      });
    });

    // Modal Logic
    var modal = document.getElementById('edit-profile-modal');
    var btnOpenEdit = document.getElementById('btn-open-edit');
    var btnOpenEditAddress = document.getElementById('btn-open-edit-address');
    var closeBtns = document.querySelectorAll('.modal-close');
    var overlay = document.querySelector('.modal-overlay');

    function openModal() {
      var pwdInput = document.getElementById('currentPassword');
      if(pwdInput) {
        pwdInput.value = '';
        pwdInput.setAttribute('readonly', 'readonly');
      }
      modal.classList.add('active');
      document.body.style.overflow = 'hidden';
    }

    function closeModal() {
      modal.classList.remove('active');
      document.body.style.overflow = '';
    }

    if(btnOpenEdit) btnOpenEdit.addEventListener('click', openModal);
    if(btnOpenEditAddress) btnOpenEditAddress.addEventListener('click', openModal);

    closeBtns.forEach(function(btn) {
      btn.addEventListener('click', closeModal);
    });

    if(overlay) overlay.addEventListener('click', closeModal);

    // Escape key to close modal
    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape' && modal.classList.contains('active')) {
        closeModal();
      }
    });

    // Check hash on load
    window.addEventListener('load', function() {
      var hash = window.location.hash;
      if (hash) {
        var tabId = hash.replace('#', ''); // e.g. 'orders'
        var navItem = document.querySelector('.user-nav-item[data-tab="' + tabId + '"]');
        if (navItem) {
          navItem.click();
        }
      }
    });
