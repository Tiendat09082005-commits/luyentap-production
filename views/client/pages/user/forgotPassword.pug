include ../../mixins/alert.pug
doctype html
html(lang="vi")
  head
    meta(charset="UTF-8")
    meta(name="viewport" content="width=device-width, initial-scale=1.0")
    meta(name="csrf-token" content=csrfToken || '')
    link(rel="stylesheet" href="/client/css/forgot-password.css")
    title Quên mật khẩu - Tida

  body
    +alert-success(3000)
    +alert-unsuccess(3000)

    .login-page
      //- ===== LEFT PANEL =====
      .login-left
        .login-left-inner
          a.login-brand(href="/")
            .brand-icon T
            span Tida

          .login-hero
            h2 Khôi phục tài khoản của bạn
            p Đừng lo lắng! Chỉ cần nhập email đã đăng ký, chúng tôi sẽ gửi hướng dẫn đặt lại mật khẩu cho bạn ngay lập tức.

          .login-stats
            .stat-item
              span.stat-number 50K+
              span.stat-label Khách hàng
            .stat-item
              span.stat-number 100%
              span.stat-label Chính hãng
            .stat-item
              span.stat-number 24/7
              span.stat-label Hỗ trợ

          .login-features
            .login-feature-item
              .feature-check
                svg(xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor")
                  path(stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7")
              .feature-text
                span.feature-name Giao hàng nhanh toàn quốc
                span.feature-desc Nhận hàng trong 24–48 giờ, miễn phí từ 500K

            .login-feature-item
              .feature-check
                svg(xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor")
                  path(stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7")
              .feature-text
                span.feature-name Bảo hành chính hãng 12–24 tháng
                span.feature-desc Đổi trả dễ dàng, hỗ trợ tận nơi

            .login-feature-item
              .feature-check
                svg(xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor")
                  path(stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7")
              .feature-text
                span.feature-name Giá tốt nhất thị trường
                span.feature-desc Cam kết hoàn tiền nếu tìm được nơi rẻ hơn

            .login-feature-item
              .feature-check
                svg(xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor")
                  path(stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7")
              .feature-text
                span.feature-name Hỗ trợ 24/7
                span.feature-desc Tư vấn viên luôn sẵn sàng giải đáp

      //- ===== RIGHT PANEL =====
      .login-right
        .login-container

          //- STEP 1: Nhập email
          .forgot-step#step-email
            .login-header
              .forgot-back-icon
                svg(xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor")
                  path(stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z")
              h1 Quên mật khẩu?
              p Nhập email đã đăng ký, chúng tôi sẽ gửi mã OTP xác nhận cho bạn.

            form(action="/user/forgot-password" method="POST" id="forgotForm")
              input(type="hidden" name="_csrf" value=csrfToken)
              .form-group
                label(for="email") Email
                input(
                  type="email"
                  id="email"
                  name="email"
                  placeholder="example@email.com"
                  required
                )

              button.btn-login(type="submit" id="btnSendOtp")
                | Gửi mã OTP
                svg(xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor")
                  path(stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7")

          //- STEP 2: Nhập OTP + mật khẩu mới (ẩn ban đầu)
          .forgot-step#step-otp(style="display:none")
            .login-header
              .forgot-back-icon.icon-otp
                svg(xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor")
                  path(stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z")
              h1 Nhập mã OTP
              p.otp-sent-desc Mã OTP đã được gửi đến email #[span#otp-email-display]
              p#otp-status

            form(action="/user/reset-password" method="POST" id="otpForm" autocomplete="off")
              input(type="hidden" name="_csrf" value=csrfToken)
              input(type="hidden" name="email" id="hiddenEmail")

              .form-group
                label Mã OTP
                .otp-inputs
                  input.otp-box(type="text" maxlength="1" inputmode="numeric" pattern="[0-9]" autocomplete="off")
                  input.otp-box(type="text" maxlength="1" inputmode="numeric" pattern="[0-9]" autocomplete="off")
                  input.otp-box(type="text" maxlength="1" inputmode="numeric" pattern="[0-9]" autocomplete="off")
                  input.otp-box(type="text" maxlength="1" inputmode="numeric" pattern="[0-9]" autocomplete="off")
                  input.otp-box(type="text" maxlength="1" inputmode="numeric" pattern="[0-9]" autocomplete="off")
                  input.otp-box(type="text" maxlength="1" inputmode="numeric" pattern="[0-9]" autocomplete="off")
                input(type="hidden" name="otp" id="otpValue")

              .form-group
                label Mật khẩu mới
                .password-input-wrap
                  input(
                    type="password"
                    id="newPassword"
                    name="newPassword"
                    placeholder="Tối thiểu 8 ký tự"
                    required
                    autocomplete="new-password"
                  )
                  button.toggle-password(type="button" tabindex="-1" data-target="newPassword")
                    svg(xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor")
                      path(stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z")
                      path(stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z")

              .form-group
                label Xác nhận mật khẩu
                .password-input-wrap
                  input(
                    type="password"
                    id="confirmPassword"
                    name="confirmPassword"
                    placeholder="Nhập lại mật khẩu"
                    required
                  )
                  button.toggle-password(type="button" tabindex="-1" data-target="confirmPassword")
                    svg(xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor")
                      path(stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z")
                      path(stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z")

              button.btn-login(type="submit")
                | Đặt lại mật khẩu
                svg(xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor")
                  path(stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7")

            .otp-resend
              span Không nhận được mã?
              button.btn-resend(type="button" id="btnResend" disabled)
                span#resendText Gửi lại sau 
                span#countdown 60
                span s
              button.btn-back-email(type="button" onclick="backToEmail()") Đổi email

          .divider
            span hoặc

          .register-link
            p Nhớ mật khẩu rồi?
              a(href="/user/login") &nbsp;Đăng nhập ngay

    script(src="/shared/js/csrf.js")
    script(src="/client/js/forgotpassword.js")
