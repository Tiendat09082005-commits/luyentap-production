extends ../../layouts/default.pug
include ../../../mixins/category-icon.pug

block css
  link(rel='stylesheet' href='/client/css/home.css')

block main
  include ../../partials/hero.pug

  section.features-bar
    .container
      .feature-item
        .feature-icon
          svg(xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24" stroke="currentColor")
            path(stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8l1 12h12L19 8")
        .feature-text
          span.feature-title Giao hàng nhanh
          span.feature-desc Trong 24-48 giờ

      .feature-item
        .feature-icon
          svg(xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24" stroke="currentColor")
            path(stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z")
        .feature-text
          span.feature-title Bảo hành chính hãng
          span.feature-desc 12-24 tháng

      .feature-item
        .feature-icon
          svg(xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24" stroke="currentColor")
            path(stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M19 11a7 7 0 01-7 7m0 0a7 7 0 01-7-7m7 7v4m0 0H8m4 0h4m-4-8a3 3 0 01-3-3V5a3 3 0 116 0v6a3 3 0 01-3 3z")
        .feature-text
          span.feature-title Hỗ trợ 24/7
          span.feature-desc Luôn sẵn sàng

      .feature-item
        .feature-icon
          svg(xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24" stroke="currentColor")
            path(stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M13 10V3L4 14h7v7l9-11h-7z")
        .feature-text
          span.feature-title Giá tốt nhất
          span.feature-desc Cam kết hoàn tiền

  if homeCategories && homeCategories.length > 0
    section.categories-section
      .container
        h2.section-title Danh mục sản phẩm
        .categories-grid
          each item in homeCategories
            a.category-card(href=item.href)
              .category-icon
                +categoryIcon(item.icon, "category-card__icon")
              .category-info
                span.category-name= item.title
                span.category-count #{item.productCount || 0} sản phẩm

  if productsFlashSale && productsFlashSale.length > 0
    section.flash-sale-section
      .container
        .flash-sale-header
          .flash-sale-title
            svg(xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="#e01c24")
              path(d="M13 10V3L4 14h7v7l9-11h-7z")
            h2 Khuyến mãi chớp nhoáng
          .flash-sale-countdown
            span.countdown-label Kết thúc trong
            .countdown-timer
              span.countdown-block#fs-hours 07
              span.countdown-sep :
              span.countdown-block#fs-minutes 59
              span.countdown-sep :
              span.countdown-block#fs-seconds 58
          a.flash-sale-viewall(href="/products?sale=flash")
            | Xem tất cả
            svg(xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor")
              path(stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7")

        .flash-sale-grid
          each item in productsFlashSale
            a.flash-card(href=`/products/detail/${item._id}`)
              .flash-badge -#{item.discount}%
              .flash-img
                img(src=item.thumbnail alt=item.title loading="lazy")
              .flash-info
                h3.flash-name #{item.title}
                .flash-rating
                  svg(xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="#f59e0b")
                    path(d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z")
                  span #{item.rating}
                .flash-price
                  span.price-current #{item.priceNew.toLocaleString()}đ
                  span.price-old #{item.price.toLocaleString()}đ
                .flash-progress
                  .flash-progress-bar(style="width: 75%")
                span.flash-sold Đã bán 45

  if productsFeatured && productsFeatured.length > 0
    section.featured-section
      .container
        .featured-header
          h2.section-title Sản phẩm nổi bật
          a.featured-viewall(href="/products")
            | Xem tất cả
            svg(xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor")
              path(stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7")

        .featured-grid
          each item in productsFeatured
            a.featured-card(href=`/products/detail/${item._id}`)
              if item.discount > 0
                .featured-badge.badge-red Giảm giá
              else
                .featured-badge.badge-blue Mới
              .featured-img
                img(src=item.thumbnail alt=item.title loading="lazy")
              .featured-info
                h3.featured-name #{item.title}
                .featured-rating
                  svg(xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="#f59e0b")
                    path(d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z")
                  span #{item.rating || 0}
                span.featured-price #{item.priceNew.toLocaleString()}đ

  if productsFlashSale && productsFlashSale.length > 0
    script.
      (function() {
        var endTime = new Date("!{siteSettings.flashSaleEndTime}").getTime();

        function updateCountdown() {
          var now = new Date().getTime();
          var diff = endTime - now;
          if (diff <= 0) {
            document.getElementById('fs-hours').textContent = '00';
            document.getElementById('fs-minutes').textContent = '00';
            document.getElementById('fs-seconds').textContent = '00';
            var section = document.querySelector('.flash-sale-section');
            if (section) section.style.display = 'none';
            return;
          }
          var h = Math.floor(diff / 3600000);
          var m = Math.floor((diff % 3600000) / 60000);
          var s = Math.floor((diff % 60000) / 1000);
          document.getElementById('fs-hours').textContent = String(h).padStart(2, '0');
          document.getElementById('fs-minutes').textContent = String(m).padStart(2, '0');
          document.getElementById('fs-seconds').textContent = String(s).padStart(2, '0');
        }

        updateCountdown();
        var timerId = setInterval(updateCountdown, 1000);
      })();
