extends ../../layouts/default.pug

block css
  link(rel="stylesheet" href="/client/css/payment.css")

block main
  .payment-page
    //- ===== PAGE HEADER =====
    .payment-header
      h1 Phương thức thanh toán
      p Chọn phương thức thanh toán phù hợp với bạn

    .payment-layout
      //- ===== LEFT COLUMN =====
      .payment-left

        //- DELIVERY INFO CARD
        .delivery-summary-card
          .delivery-summary-top
            .delivery-to
              span.delivery-label Giao đến
              p.delivery-name= userInfo.fullName
              p.delivery-sub= userInfo.phone
              p.delivery-sub
                if userInfo.address && (typeof userInfo.address === 'object')
                  | #{userInfo.address.street}, #{userInfo.address.wardName}, #{userInfo.address.districtName}, #{userInfo.address.provinceName}
                else
                  | #{userInfo.address}
            a.delivery-change(href="/checkout/payment-info") Thay đổi
          .delivery-divider
          .delivery-method
            span Phương thức:&nbsp;
            strong= shippingMethod || 'Giao hàng nhanh'

        //- PAYMENT METHODS CARD
        .payment-methods-card
          .payment-methods-title
            .payment-methods-icon
              svg(xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor")
                path(stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z")
            div
              h3 Phương thức thanh toán
              p Chọn hình thức thanh toán phù hợp với bạn

          form(action="/checkout/order" method="POST" id="paymentForm")
            input(type="hidden" name="_csrf" value=csrfToken)
            input(type="hidden" name="checkoutToken" value=checkoutToken)

            .payment-options



              //- ── 2. CHUYỂN KHOẢN NGÂN HÀNG ──
              .payment-option#opt-bank
                .payment-option-header(onclick="togglePayment('bank')")
                  .payment-option-left
                    .payment-radio#radio-bank
                      .radio-dot
                    .payment-option-icon.icon-bank
                      svg(xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor")
                        path(stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 14v3m4-3v3m4-3v3M3 21h18M3 10h18M3 7l9-4 9 4M4 10h16v11H4V10z")
                    .payment-option-info
                      span.payment-option-name Chuyển khoản ngân hàng
                      span.payment-option-desc Chuyển khoản qua Internet Banking hoặc ATM
                  svg.payment-chevron(xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor")
                    path(stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7")

                .payment-option-body#body-bank
                  p.bank-select-label Chọn ngân hàng của bạn để chuyển khoản
                  -
                    var banks = [
                      { name: 'Vietcombank', logo: '/client/images/banks/logoVietcombank.png' },
                      { name: 'Techcombank', logo: '/client/images/banks/logotechcombank.png' },
                      { name: 'MB Bank',     logo: '/client/images/banks/mbbank.png' },
                      { name: 'BIDV',        logo: '/client/images/banks/bidv.png' },
                      { name: 'ACB',         logo: '/client/images/banks/acb.png' },
                      { name: 'VPBank',      logo: '/client/images/banks/vpbank.png' },
                      { name: 'TPBank',      logo: '/client/images/banks/tpbank.png' },
                      { name: 'Sacombank',   logo: '/client/images/banks/sacombank.png' }
                    ]
                  .bank-grid
                    each bank in banks
                      button.bank-item(type="button" onclick="selectBank(this)")
                        img.bank-logo-img(src=bank.logo alt=bank.name onerror="this.style.display='none'")
                        span= bank.name

              //- ── 3. VÍ ĐIỆN TỬ ──
              .payment-option#opt-ewallet
                .payment-option-header(onclick="togglePayment('ewallet')")
                  .payment-option-left
                    .payment-radio#radio-ewallet
                      .radio-dot
                    //- Hiển thị 4 mini logo ví trong header
                    .payment-option-icon.icon-ewallet
                      svg(xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="#d53988")
                        path(stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z")
                    .payment-option-info
                      span.payment-option-name Ví điện tử
                      span.payment-option-desc MoMo, ZaloPay, VNPay, ShopeePay
                  svg.payment-chevron(xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor")
                    path(stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7")

                .payment-option-body#body-ewallet
                  p.bank-select-label Chọn ví điện tử để thanh toán
                  .ewallet-grid

                    //- MoMo
                    button.ewallet-item(type="button" onclick="selectWallet(this)")
                      img.ewallet-logo-img(
                        src="/client/images/Electronic wallet/momo.png"
                        alt="MoMo"
                        onerror="this.style.display='none'"
                      )
                      span MoMo

                    //- ZaloPay
                    button.ewallet-item(type="button" onclick="selectWallet(this)")
                      img.ewallet-logo-img(
                        src="https://cdn.haitrieu.com/wp-content/uploads/2022/10/Logo-ZaloPay-Square.png"
                        alt="ZaloPay"
                        onerror="this.style.display='none'"
                      )
                      span ZaloPay

                    //- VNPay
                    button.ewallet-item(type="button" onclick="selectWallet(this)")
                      img.ewallet-logo-img(
                        src="https://cdn.haitrieu.com/wp-content/uploads/2022/10/Icon-VNPAY-QR.png"
                        alt="VNPay"
                        onerror="this.style.display='none'"
                      )
                      span VNPay

                    //- ShopeePay
                    button.ewallet-item(type="button" onclick="selectWallet(this)")
                      img.ewallet-logo-img(
                        src="/client/images/Electronic wallet/shoppepay.png"
                        alt="ShopeePay"
                        onerror="this.style.display='none'"
                      )
                      span ShopeePay

              //- ── 4. COD ──
              .payment-option#opt-cod
                .payment-option-header(onclick="togglePayment('cod')")
                  .payment-option-left
                    .payment-radio#radio-cod
                      .radio-dot
                    .payment-option-icon.icon-cod
                      svg(xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor")
                        path(stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 9V7a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2m2 4h10a2 2 0 002-2v-6a2 2 0 00-2-2H9a2 2 0 00-2 2v6a2 2 0 002 2zm7-5a2 2 0 11-4 0 2 2 0 014 0z")
                    .payment-option-info
                      span.payment-option-name Thanh toán khi nhận hàng (COD)
                      span.payment-option-desc Thanh toán bằng tiền mặt khi nhận hàng
                  svg.payment-chevron(xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor")
                    path(stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7")

                .payment-option-body#body-cod
                  .cod-notice
                    svg(xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" style="flex-shrink:0;margin-top:2px")
                      path(stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7")
                    div
                      p.cod-notice-title Thanh toán khi nhận hàng
                      p.cod-notice-desc
                        | Bạn sẽ thanh toán&nbsp;
                        strong #{totalPrice ? totalPrice.toLocaleString('vi-VN') : 0}đ
                        |  bằng tiền mặt khi nhận hàng. Vui lòng chuẩn bị số tiền đúng để shipper dễ giao hàng.

            //- SECURITY NOTICE
            .security-notice
              svg(xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" style="flex-shrink:0")
                path(stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z")
              .security-text
                span Thanh toán an toàn và bảo mật
                span Thông tin thanh toán của bạn được mã hóa và bảo vệ bởi SSL 256-bit
              svg(xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" style="flex-shrink:0")
                path(stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z")

        //- BOTTOM ACTIONS
        .payment-actions
          a.btn-back(href="/checkout/payment-info") Quay lại
          button#btn-pay.btn-pay(type="submit" form="paymentForm")
            | Thanh toán #{totalPrice ? totalPrice.toLocaleString('vi-VN') : 0}đ

      //- ===== RIGHT: ORDER SUMMARY =====
      .payment-right
        .order-summary
          .summary-header
            h3 Đơn hàng của bạn
            span.summary-count #{products.length} sản phẩm

          .product-list
            each product in products
              .product-item
                .product-img-wrap
                  img(src=product.thumbnail alt=product.slug)
                .product-details
                  p.product-name= product.title
                  .product-meta
                    span.product-variant= (product.variant || '')
                    span.product-quantity  x #{product.quantity || 1}
                  span.product-price #{product.price ? Number(product.price).toLocaleString('vi-VN') : 0}đ

          .summary-divider

          .summary-rows
            .summary-row
              span Tạm tính
              span #{totalPrice ? totalPrice.toLocaleString('vi-VN') : 0}đ
            .summary-row
              span Phí vận chuyển
              span.shipping-free Miễn phí

          .summary-divider

          .summary-total-row
            span Tổng cộng
            span.total-price #{totalPrice ? totalPrice.toLocaleString('vi-VN') : 0}đ

          .summary-badges
            .summary-badge
              svg(xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor")
                path(stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z")
              span Bảo hành chính hãng
            .summary-badge
              svg(xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor")
                path(stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z")
              span Thanh toán an toàn
            .summary-badge
              svg(xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor")
                path(stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15")
              span Đổi trả 30 ngày

  script.
    window.__TOTAL_PRICE__ = !{totalPrice ? totalPrice : 0};
  script(src="/client/js/payment.js")

