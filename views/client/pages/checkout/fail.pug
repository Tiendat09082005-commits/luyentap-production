extends ../../layouts/default.pug

block css
  link(rel="stylesheet" href="/client/css/payment-fail.css")

block main
  .failed-page

    //- ===== HERO =====
    .failed-hero
      .failed-icon
        svg(xmlns="http://www.w3.org/2000/svg" width="32" height="32" fill="none" viewBox="0 0 24 24" stroke="currentColor")
          path(stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 18L18 6M6 6l12 12")
      h1 Đặt hàng thất bại
      p Rất tiếc, chúng tôi không thể xử lý đơn hàng của bạn. Vui lòng thử lại hoặc chọn phương thức thanh toán khác.

    //- ===== ERROR NOTICE =====
    .error-notice
      .error-notice-top
        .error-notice-icon
          svg(xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor")
            path(stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z")
        div
          p.error-title Thanh toán bị từ chối
          p.error-code Mã lỗi: #{error.code || 'ERR_PAY_001'}

      .error-detail
        p= error.message || 'Giao dịch không thể hoàn tất do thẻ của bạn bị ngân hàng phát hành từ chối.'

      .error-suggestions
        p.suggestions-title
          svg(xmlns="http://www.w3.org/2000/svg" width="15" height="15" fill="none" viewBox="0 0 24 24" stroke="currentColor")
            path(stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z")
          | Đề xuất xử lý
        ul.suggestions-list
          li
            svg(xmlns="http://www.w3.org/2000/svg" width="13" height="13" fill="none" viewBox="0 0 24 24" stroke="currentColor")
              path(stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7")
            | Kiểm tra số dư tài khoản và hạn mức thẻ
          li
            svg(xmlns="http://www.w3.org/2000/svg" width="13" height="13" fill="none" viewBox="0 0 24 24" stroke="currentColor")
              path(stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7")
            | Liên hệ ngân hàng để xác nhận giao dịch
          li
            svg(xmlns="http://www.w3.org/2000/svg" width="13" height="13" fill="none" viewBox="0 0 24 24" stroke="currentColor")
              path(stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7")
            | Thử sử dụng phương thức thanh toán khác

    //- ===== TRANSACTION DETAIL =====
    .transaction-card
      h3 Chi tiết giao dịch
      .transaction-grid
        .transaction-item
          span.transaction-label Ngày giao dịch
          span.transaction-value #{new Date(order.createdAt || Date.now()).toLocaleDateString('vi-VN')}
        .transaction-item
          span.transaction-label Thời gian
          span.transaction-value #{new Date(order.createdAt || Date.now()).toLocaleTimeString('vi-VN', {hour:'2-digit', minute:'2-digit', second:'2-digit'})}
        .transaction-item
          span.transaction-label Phương thức
          span.transaction-value= order.paymentMethodText || 'VNPay'
        .transaction-item
          span.transaction-label Số tiền
          span.transaction-value.amount= (order.totalPrice || 0).toLocaleString('vi-VN') + 'đ'

    //- ===== ACTION CARDS =====
    .action-cards
      a.action-card.action-retry(href=`/checkout/payment-info`)
        .action-card-icon
          svg(xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor")
            path(stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15")
        .action-card-info
          span Thử lại thanh toán
          span Quay lại bước thanh toán
        svg(xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor")
          path(stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7")

      a.action-card.action-change(href=`/checkout/payment-info`)
        .action-card-icon
          svg(xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor")
            path(stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z")
        .action-card-info
          span Đổi phương thức
          span Chọn phương thức khác
        svg(xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor")
          path(stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7")

    //- ===== REFUND NOTICE =====
    .refund-notice
      svg(xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor")
        path(stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z")
      div
        p.refund-title Lưu ý quan trọng
        p.refund-desc
          | Nếu tài khoản của bạn đã bị trừ tiền nhưng đơn hàng không thành công, số tiền sẽ được hoàn lại trong vòng 3-6 ngày làm việc. Nếu quá thời gian trên mà bạn chưa nhận được tiền hoàn, vui lòng liên hệ bộ phận hỗ trợ.

    //- ===== BOTTOM ACTIONS =====
    .failed-actions
      a.btn-back(href="/cart") Quay lại giỏ hàng
      a.btn-retry(href="/checkout/payment-info")
        svg(xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor")
          path(stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15")
        | Thử lại thanh toán

    //- ===== SUPPORT =====
    .support-card
      .support-icon
        svg(xmlns="http://www.w3.org/2000/svg" width="28" height="28" fill="none" viewBox="0 0 24 24" stroke="currentColor")
          path(stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M18.364 5.636l-3.536 3.536m0 5.656l3.536 3.536M9.172 9.172L5.636 5.636m3.536 9.192l-3.536 3.536M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-5 0a4 4 0 11-8 0 4 4 0 018 0z")
      h3 Cần hỗ trợ?
      p Đội ngũ hỗ trợ của chúng tôi luôn sẵn sàng giúp đỡ bạn 24/7
      .support-contacts
        .support-contact
          svg(xmlns="http://www.w3.org/2000/svg" width="15" height="15" fill="none" viewBox="0 0 24 24" stroke="currentColor")
            path(stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z")
          span Hotline: 
          strong 1900 1234
        .support-contact
          svg(xmlns="http://www.w3.org/2000/svg" width="15" height="15" fill="none" viewBox="0 0 24 24" stroke="currentColor")
            path(stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z")
          span Email: 
          strong support@tida.vn
      a.btn-chat(href="/support")
        svg(xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor")
          path(stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z")
        | Chat với hỗ trợ
