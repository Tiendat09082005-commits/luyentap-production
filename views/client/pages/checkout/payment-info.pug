extends ../../layouts/default.pug

block css
  link(rel="stylesheet" href="/client/css/payment-info.css")

block main
  .checkout-page
    //- ===== PAGE HEADER =====
    .checkout-header
      h1 Thông tin nhận hàng
      p Vui lòng nhập thông tin để chúng tôi giao hàng cho bạn

    form(action="/checkout/payment" method="POST" id="checkoutForm")
      input(type="hidden" name="_csrf" value=csrfToken)
      //- Hidden fields
      input(type="hidden" name="user_id" value=user._id)
      input(type="hidden" name="totalPrice" value=totalPrice)
      each product, index in products
        input(type="hidden" name=`products[${index}][product_id]` value=product._id)
        input(type="hidden" name=`products[${index}][variant_id]` value=product.variant_id)
        input(type="hidden" name=`products[${index}][title]` value=product.title)
        input(type="hidden" name=`products[${index}][thumbnail]` value=product.thumbnail)
        input(type="hidden" name=`products[${index}][price]` value=product.priceNew)
        input(type="hidden" name=`products[${index}][discountPercentage]` value=product.discount)
        input(type="hidden" name=`products[${index}][quantity]` value=product.quantity)

      .checkout-layout

        //- ===== LEFT COLUMN =====
        .checkout-left

          //- THÔNG TIN KHÁCH HÀNG
          .checkout-card
            .checkout-card-title
              .card-title-icon
                svg(xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor")
                  path(stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z")
              div
                h3 Thông tin liên hệ
                p Chúng tôi sẽ liên hệ với bạn qua thông tin này

            .customer-info-section
              .form-group
                label HỌ VÀ TÊN
                input.form-input(
                  type="text"
                  name="userInfo[fullName]"
                  value=user.fullName
                  required
                )

              .form-grid
                .form-group.half
                  label SỐ ĐIỆN THOẠI
                  input.form-input(
                    type="tel"
                    name="userInfo[phone]"
                    value=user.phone
                    required
                  )
                .form-group.half
                  label EMAIL
                  input.email-input.form-input(
                    type="email"
                    value=user.email
                    readonly
                  )

          //- THÔNG TIN NHẬN HÀNG
          .checkout-card
            .checkout-card-title
              .card-title-icon
                svg(xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor")
                  path(stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z")
                  path(stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z")
              div
                h3 Địa chỉ nhận hàng
                p Địa chỉ nhận hàng của bạn

            .delivery-info-section
              .form-grid-three
                .form-group.third
                  label TỈNH / THÀNH PHỐ
                  select.form-select(name="userInfo[address][province]" required button-province)
                    option(value="20" selected) Bà Rịa - Vũng Tàu

                .form-group.third
                  label QUẬN / HUYỆN
                  select.form-select(name="userInfo[address][district]" required button-district)
                    option(value="" disabled selected) Chọn quận/huyện

                .form-group.third
                  label PHƯỜNG / XÃ
                  select.form-select(name="userInfo[address][ward]" required button-ward)
                    option(value="" disabled selected) Chọn phường/xã

              .form-group
                label ĐỊA CHỈ CỤ THỂ
                input.form-input(
                  type="text"
                  name="userInfo[address][street]"
                  placeholder="Số nhà, tên đường"
                  required
                )
                span.input-hint Ví dụ: 123 Nguyễn Huệ, Tầng 5, Phòng 501

              .form-group
                label GHI CHÚ (Tùy chọn)
                textarea.form-textarea(
                  name="note"
                  rows="3"
                  placeholder="Ghi chú thêm cho đơn hàng..."
                )

          //- FOOTER ACTIONS
          .checkout-actions
            a.btn-back(href="/cart")
              svg(xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor")
                path(stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7")
              | Quay lại giỏ hàng
            button.btn-submit(type="submit")
              | Tiếp tục thanh toán
              svg(xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor")
                path(stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7")

        //- ===== RIGHT COLUMN: ORDER SUMMARY =====
        .checkout-right
          .order-summary
            .summary-header
              h3 Đơn hàng của bạn
              span.summary-count #{products.length} sản phẩm

            .product-info
              each product in products
                .product-item
                  .product-image-wrap
                    img.product-image(src=product.thumbnail alt=product.slug)
                  .product-details
                    h4.product-name #{product.title}
                    span.product-variant= product.variant || ''
                    .product-price
                      span.price-current #{product.priceNew ? product.priceNew.toLocaleString('vi-VN') : 0}đ

            .summary-divider

            .summary-rows
              .summary-row
                span.summary-label Tạm tính
                span.summary-value #{totalPrice ? totalPrice.toLocaleString('vi-VN') : 0}đ
              .summary-row
                span.summary-label Phí vận chuyển
                span.summary-ship 0đ

            .summary-divider

            .summary-total-row
              span Tổng cộng
              span.summary-total= totalPrice.toLocaleString('vi-VN') + ' ₫'

            .summary-badges
              .summary-badge
                svg(xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor")
                  path(stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z")
                span Bảo hành chính hãng
              .summary-badge
                svg(xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor")
                  path(stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z")
                span Thanh toán an toàn
              .summary-badge
                svg(xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor")
                  path(stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15")
                span Đổi trả 30 ngày

  script(src="/client/js/order.js")
  script.
    // Shipping option toggle
    document.querySelectorAll('.shipping-option').forEach(function(opt) {
      opt.addEventListener('click', function() {
        document.querySelectorAll('.shipping-option').forEach(function(o) {
          o.classList.remove('selected');
        });
        this.classList.add('selected');
      });
    });
