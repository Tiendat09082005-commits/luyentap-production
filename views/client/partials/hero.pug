- var ss = siteSettings || {}

section.hero-banner
  .hero-content
    .hero-text
      span.hero-label Khuyến mãi đặc biệt
      h1.hero-title= ss.heroHeading || 'iPhone 15 Series'
      h2.hero-discount Giảm đến 20%
      p.hero-desc= ss.heroSubheading || 'Trải nghiệm công nghệ đỉnh cao với camera 48MP và chip A17 Pro mạnh mẽ nhất.'
      a.hero-btn(href=ss.heroCtaLink || '/products')
        | #{ss.heroCtaText || 'Mua ngay'}
        svg(xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor")
          path(stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7")
    .hero-image
      if ss.heroImageUrl
        img(src=ss.heroImageUrl alt=ss.heroHeading || 'Hero image')
      else
        img(src="/assets/images/iphone15-banner.png" alt=ss.heroHeading || 'iPhone 15 Series')
