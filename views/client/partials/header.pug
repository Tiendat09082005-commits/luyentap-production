include ../mixins/nav-categories.pug

header.site-header
  .header-top
    .container
      .header-top-marquee
        .marquee-track
          span Miễn phí vận chuyển cho đơn hàng từ 500.000đ
          span •
          span Giảm thêm 5% khi thanh toán online
          span •
          span Bảo hành chính hãng 12-24 tháng
          span •
          span Miễn phí vận chuyển cho đơn hàng từ 500.000đ
          span •
          span Giảm thêm 5% khi thanh toán online
          span •
          span Bảo hành chính hãng 12-24 tháng
          span •
      .header-top-right
        if user
          a(href=`/user/detail/${user.id}#orders`) Tra cứu đơn hàng
        else
          a(href="/user/login") Tra cứu đơn hàng
        span.divider |
        a(href="#") Hỗ trợ

  .header-main
    .container
      a.logo(href="/") Tida

      .location-picker
        svg(xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor")
          path(stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z")
          path(stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z")
        span Hồ Chí Minh
        svg.chevron(xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor")
          path(stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7")

      .search-bar
        form(action="/products" method="GET" id="headerSearchForm")
          svg(xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor")
            path(stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z")
          input(type="text" name="keyword" id="headerSearchInput" placeholder="Tìm kiếm sản phẩm..." autocomplete="off" data-search-entity="products" value=(keyword ? keyword : ''))
          .search-results-dropdown#searchResultContainer

      .header-actions
        if user
          a.action-btn(href=`/user/detail/${user.id}`)
            svg(xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="none" viewBox="0 0 24 24" stroke="currentColor")
              path(stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z")
            span #{user.fullName.split(' ').pop()}
        else
          a.action-btn(href="/user/login")
            svg(xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="none" viewBox="0 0 24 24" stroke="currentColor")
              path(stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z")
            span Tài khoản

        a.action-btn.cart-btn(href="/cart")
          .cart-icon-wrap
            svg(xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="none" viewBox="0 0 24 24" stroke="currentColor")
              path(stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z")
            .cart-badge #{itemInCart}
          span Giỏ hàng

  +nav-categories(megaMenuCategories)
