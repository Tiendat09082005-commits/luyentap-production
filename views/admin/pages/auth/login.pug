extends ../../layouts/auth.pug
include ../../mixins/alert.pug


block css
  link(rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700&display=swap")
  link(rel="stylesheet" href="/admin/css/login.css")

block main
  .auth-wrapper
    .auth-left
      h2 Nhanh chóng, hiệu quả và năng suất
      p Chào mừng trở lại ! Vui lòng đăng nhập để truy cập bảng điều khiển và quản lý cửa hàng công nghệ của bạn.

      .auth-footer
        nav
          a(href="#") Điều khoản
          a(href="#") Kế họach
          a(href="#") Liên hệ với chúng tôi

    .auth-card
      h1 Đăng nhập

      +alert-success(5000)
      +alert-error(5000)

      form(action=prefixAdmin + "/auth/login" method="POST")
        input(type="hidden" name="_csrf" value=csrfToken)

        .form-group
          label(for="email") Email
          input(
            type="email"
            id="email"
            name="email"
            class="form-control"
            required
            autocomplete="email"
          )

        .form-group
          label(for="password") Mật khẩu
          .input-wrap
            input(
              type="password"
              id="password"
              name="password"
              class="form-control"
              required
              autocomplete="current-password"
            )
            button.toggle-pw(type="button" aria-label="Hiển thị/Ẩn mật khẩu" onclick="togglePassword(this)")
              svg(xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2")
                path(stroke-linecap="round" stroke-linejoin="round" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.543-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l3.59 3.59m0 0A9.953 9.953 0 0112 5c4.478 0 8.268 2.943 9.543 7a10.025 10.025 0 01-4.132 4.411m0 0L21 21")
          p.pw-hint Mật khẩu tối thiểu 6 ký tự.

        .terms-row
          input(type="checkbox" id="terms" name="terms")
          label(for="terms") Tôi đồng ý với &nbsp;
            a(href="#") Điều khoản

        button.btn-primary-block(type="submit") Đăng nhập

block script
  script(src="/admin/js/login.js")
