extends ../../layouts/default.pug

block css
  link(rel="stylesheet", href="/admin/css/detailRole.css")

block main
  if(roles.permissions.includes("roles_view"))
    .role-page
      .role-card
        .role-card__header
          span.role-card__tag Chi tiết nhóm quyền
          h1.role-card__title #{record.title}
        
        .role-card__body
          //- 1. Mô tả
          .role-section
            span.role-section__label Mô tả vai trò
            if (record.description)
              .role-section__desc !{record.description}
            else
              .role-section__desc.text-muted Không có mô tả chi tiết cho nhóm quyền này.
          
          hr.role-divider

          //- 2. Quyền hạn
          .role-section
            span.role-section__label Quyền hạn được cấp
            if (record.permissions && record.permissions.length > 0)
              .role-perms
                each item in record.permissions
                  span.role-perm-pill #{item}
            else
              .role-no-perm 
                svg(xmlns='http://www.w3.org/2000/svg' width='14' height='14' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' style='margin-right: 6px; vertical-align: middle;')
                  circle(cx='12' cy='12' r='10')
                  line(x1='4.93' y1='4.93' x2='19.07' y2='19.07')
                | Chưa được phân quyền cụ thể
          
          hr.role-divider

          //- 3. Meta info
          .role-meta
            .role-meta__item
              span.role-meta__label Trạng thái
              if (record.deleted)
                span.role-badge.role-badge--deleted Ngưng hoạt động
              else 
                span.role-badge.role-badge--active Đang hoạt động
            
            .role-meta__item
              span.role-meta__label Ngày tạo lập
              span.role-meta__value #{new Date(record.createdAt).toLocaleString()} 

            .role-meta__item
              span.role-meta__label Cập nhật cuối
              span.role-meta__value #{new Date(record.updatedAt).toLocaleString()}

        .role-card__footer
          a.role-btn.role-btn--back(href=`${prefixAdmin}/roles`) 
            svg(xmlns='http://www.w3.org/2000/svg' width='14' height='14' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' style='margin-right: 6px;')
              polyline(points='15 18 9 12 15 6')
            | Quay lại danh sách
          if(roles.permissions.includes("roles_edit"))
            a.role-btn.role-btn--edit(href=`${prefixAdmin}/roles/edit/${record.id}`) 
              svg(xmlns='http://www.w3.org/2000/svg' width='14' height='14' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' style='margin-right: 6px;')
                path(d='M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7')
                path(d='M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z')
              | Chỉnh sửa vai trò
                  
    script(src="/admin/js/product.js")
  else 
    h1 Bạn không được cấp quyền xem sản phẩm
