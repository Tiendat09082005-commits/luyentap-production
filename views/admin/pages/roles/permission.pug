extends ../../layouts/default.pug
include ../../mixins/alert.pug
block css
    link(rel="stylesheet", href="/admin/css/permissions.css")
block main
    if(roles.permissions.includes("roles_permissions"))
        .permissions-page 
            +alert-success(5000)

            h1 Phân quyền
            
            if(records)
                div(data-records = records)
                div(class="text-right")
                button(type="submit" class="btn btn-primary mb-3" button-submit) Cập nhật
                table(
                    class="table table-hover table-sm"
                    table-permission
                )
                    thead
                        tr
                            th Tính năng
                                each item in records
                                    th(class="text-center") #{item.title.toUpperCase()}
                    tbody
                        tr(data-name = "id" class = "d-none") 
                            td
                            each item in records
                                td(class = "text-center")
                                    input(type = "text" value=item._id)
                        tr
                            td(colspan= records.length + 1)
                                b Danh mục sản phẩm
                        tr(data-name="products-category_view")
                            td Xem
                            each item in records
                                td(class="text-center")
                                    input(type="checkbox")
                        tr(data-name="products-category_create")
                            td Thêm mới
                            each item in records
                                td(class="text-center")
                                    input(type="checkbox")
                        tr(data-name="products-category_edit")
                            td Chỉnh sửa
                            each item in records
                                td(class="text-center")
                                    input(type="checkbox")
                        tr(data-name="products-category_delete")
                            td Xóa
                            each item in records
                                td(class="text-center")
                                    input(type="checkbox")
                        //- Sản Phẩm 
                        tr
                            td(colspan= records.length + 1)
                                b  Sản phẩm
                        tr(data-name="products_view")
                            td Xem
                            each item in records
                                td(class="text-center")
                                    input(type="checkbox")
                        tr(data-name="products_create")
                            td Thêm mới
                            each item in records
                                td(class="text-center")
                                    input(type="checkbox")
                        tr(data-name="products_edit")
                            td Chỉnh sửa
                            each item in records
                                td(class="text-center")
                                    input(type="checkbox")
                        tr(data-name="products_delete")
                            td Xóa
                            each item in records
                                td(class="text-center")
                                    input(type="checkbox")
                        tr(data-name="products_view_trash")
                            td Xem thùng rác
                            each item in records
                                td(class="text-center")
                                    input(type="checkbox")
                        //- Nhóm quyền roles
                        tr
                            td(colspan= records.length + 1)
                                b  Nhóm quyền
                        tr(data-name="roles_view")
                            td Xem
                            each item in records
                                td(class="text-center")
                                    input(type="checkbox")
                        tr(data-name="roles_create")
                            td Thêm mới
                            each item in records
                                td(class="text-center")
                                    input(type="checkbox")
                        tr(data-name="roles_edit")
                            td Chỉnh sửa
                            each item in records
                                td(class="text-center")
                                    input(type="checkbox")
                        tr(data-name="roles_delete")
                            td Xóa
                            each item in records
                                td(class="text-center")
                                    input(type="checkbox")
                        tr(data-name="roles_permissions")
                            td Phân quyền
                            each item in records
                                td(class="text-center")
                                    input(type="checkbox")
                        //- tài khoản account 
                        tr
                            td(colspan= records.length + 1)
                                b  Tài Khoản
                        tr(data-name="account_view")
                            td Xem
                            each item in records
                                td(class="text-center")
                                    input(type="checkbox")
                        tr(data-name="account_create")
                            td Thêm mới
                            each item in records
                                td(class="text-center")
                                    input(type="checkbox")
                        tr(data-name="account_edit")
                            td Chỉnh sửa
                            each item in records
                                td(class="text-center")
                                    input(type="checkbox")
                        tr(data-name="account_delete")
                            td Xóa
                            each item in records
                                td(class="text-center")
                                    input(type="checkbox")
                        //- Thương hiệu brand
                        tr
                            td(colspan= records.length + 1)
                                b Thương hiệu
                        tr(data-name="brands_view")
                            td Xem
                            each item in records
                                td(class="text-center")
                                    input(type="checkbox")
                        tr(data-name="brands_create")
                            td Thêm mới
                            each item in records
                                td(class="text-center")
                                    input(type="checkbox")
                        tr(data-name="brands_edit")
                            td Chỉnh sửa
                            each item in records
                                td(class="text-center")
                                    input(type="checkbox")
                        tr(data-name="brands_delete")
                            td Xóa
                            each item in records
                                td(class="text-center")
                                    input(type="checkbox")
                        //- Thuộc tính attribute
                        tr
                            td(colspan= records.length + 1)
                                b Thuộc tính
                        tr(data-name="attributes_view")
                            td Xem
                            each item in records
                                td(class="text-center")
                                    input(type="checkbox")
                        tr(data-name="attributes_create")
                            td Thêm mới
                            each item in records
                                td(class="text-center")
                                    input(type="checkbox")
                        tr(data-name="attributes_edit")
                            td Chỉnh sửa
                            each item in records
                                td(class="text-center")
                                    input(type="checkbox")
                        tr(data-name="attributes_delete")
                            td Xóa
                            each item in records
                                td(class="text-center")
                                    input(type="checkbox")
                        //- Đơn hàng order
                        tr
                            td(colspan= records.length + 1)
                                b Đơn hàng
                        tr(data-name="orders_view")
                            td Xem
                            each item in records
                                td(class="text-center")
                                    input(type="checkbox")
                        tr(data-name="orders_edit")
                            td Chỉnh sửa (Trạng thái)
                            each item in records
                                td(class="text-center")
                                    input(type="checkbox")
                        tr(data-name="orders_delete")
                            td Xóa
                            each item in records
                                td(class="text-center")
                                    input(type="checkbox")

                        //- Tin nhắn
                        tr
                            td(colspan= records.length + 1)
                                b Tin nhắn hỗ trợ
                        tr(data-name="messages_support")
                            td Hỗ trợ khách hàng
                            each item in records
                                td(class="text-center")
                                    input(type="checkbox")

                        //- Cài đặt
                        tr
                            td(colspan= records.length + 1)
                                b Cài đặt hệ thống
                        tr(data-name="settings_view")
                            td Xem
                            each item in records
                                td(class="text-center")
                                    input(type="checkbox")

            form(
                id="form-change-permissions"
                method="POST"
                action=`${prefixAdmin}/roles/permission?_method=PATCH`
            )
                input(type="hidden" name="_csrf" value=csrfToken)
                div(class="form-group")
                    input(
                        type="text"
                        class="form-control"
                        name="permissions"
                        class = "d-none"
                    )
            
            script(src = "/admin/js/role.js")
