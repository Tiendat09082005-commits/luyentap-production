extends ../../layouts/default.pug


block css
    link(rel="stylesheet", href="/admin/css/settings.css")
block main
  .settings-page
    .settings-header
      .settings-header__icon
        svg(xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5")
          path(d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z")
          circle(cx="12" cy="12" r="3")
      .settings-header__text
        h1.settings-header__title Cài đặt hệ thống
        p.settings-header__subtitle Quản lý thông tin & giao diện hiển thị cho khách hàng

    form.settings-form(action=`${prefixAdmin}/setting?_csrf=${csrfToken}` method="POST" enctype="multipart/form-data")
      input(type="hidden" name="_csrf" value=csrfToken)
      input(type="hidden" name="removeHeroImage" id="removeHeroImage" value="false")

      //- ── NHÓM 1: THÔNG TIN TRANG WEB ──────────────────────────────
      .settings-section
        .settings-section__label
          span.settings-section__number 01
          h2.settings-section__title Thông tin trang web
          p.settings-section__desc Tên và mô tả của trang web hiển thị trên tab trình duyệt & kết quả tìm kiếm

        .settings-section__fields
          .field-group
            .field
              label.field__label(for="siteName") Tên trang web
              .field__control
                input.field__input(
                  type="text"
                  id="siteName"
                  name="siteName"
                  value=settings.siteName
                  placeholder="Ví dụ: Thế Giới Nội Thất"
                  autocomplete="off"
                )
              p.field__hint Hiển thị trên tab trình duyệt và tiêu đề trang

            .field
              label.field__label(for="siteSlogan") Khẩu hiệu (tagline)
              .field__control
                input.field__input(
                  type="text"
                  id="siteSlogan"
                  name="siteSlogan"
                  value=settings.siteSlogan
                  placeholder="Ví dụ: Nâng tầm không gian sống"
                  autocomplete="off"
                )
              p.field__hint Dòng mô tả ngắn bên dưới tên trang

          .field
            label.field__label(for="metaDescription") Mô tả SEO
            .field__control
              textarea.field__input.field__input--textarea(
                id="metaDescription"
                name="metaDescription"
                rows="3"
                placeholder="Mô tả ngắn về trang web, tối đa 160 ký tự..."
                maxlength="160"
              )= settings.metaDescription
            .field__hint-row
              p.field__hint Hiển thị trong kết quả tìm kiếm Google
              span.field__counter#metaCounter #{settings.metaDescription ? settings.metaDescription.length : 0}/160

      //- ── NHÓM 2: THANH CHẠY CHỮ (MARQUEE) ─────────────────────────
      .settings-section
        .settings-section__label
          span.settings-section__number 02
          h2.settings-section__title Dòng chữ chạy (Marquee)
          p.settings-section__desc Văn bản cuộn liên tục trên tiêu đề trang

        .settings-section__fields
          .field
            label.field__label(for="marqueeText") Nội dung chạy chữ
            .field__control
              textarea.field__input.field__input--textarea(
                id="marqueeText"
                name="marqueeText"
                rows="2"
                placeholder="Ví dụ: 🎉 Khuyến mãi đến 50% | Miễn phí vận chuyển toàn quốc | Đặt hàng ngay hôm nay..."
              )= settings.marqueeText
            p.field__hint Dùng ký tự | để phân cách các đoạn thông báo

          .field-row
            .field
              label.field__label(for="marqueeSpeed") Tốc độ cuộn
              .field__control
                .slider-wrap
                  input.slider(
                    type="range"
                    id="marqueeSpeed"
                    name="marqueeSpeed"
                    min="20"
                    max="120"
                    step="5"
                    value=settings.marqueeSpeed || 60
                  )
                  span.slider__value #{settings.marqueeSpeed || 60}s

            .field
              label.field__label Hiển thị
              .toggle-group
                label.toggle
                  input.toggle__input(
                    type="checkbox"
                    name="marqueeEnabled"
                    id="marqueeEnabled"
                    checked=settings.marqueeEnabled
                  )
                  span.toggle__track
                  span.toggle__label Bật dòng chữ chạy

      //- ── NHÓM 3: HERO SECTION ───────────────────────────────────────
      .settings-section
        .settings-section__label
          span.settings-section__number 03
          h2.settings-section__title Khu vực Hero
          p.settings-section__desc Cấu hình chi tiết các slide nổi bật hiển thị trên trang chủ

        .settings-section__fields
          .field
            label.field__label Danh sách các Slide
            .hero-slides-list#heroSlidesList
              if settings.heroSlides && settings.heroSlides.length > 0
                each slide, index in settings.heroSlides
                  .hero-slide-editor-card(data-index=index)
                    .slide-card-header
                      h3.slide-card-title Slide #
                        span.slide-number= index + 1
                      button.btn-delete-slide(type="button" onclick="deleteSlideCard(this)") Xóa slide
                    .slide-card-body
                      .slide-image-section
                        .slide-image-preview
                          if slide.imageUrl
                            img(src=slide.imageUrl alt=`Slide Preview ${index + 1}`)
                          else
                            .no-image Chưa chọn ảnh
                        .slide-image-upload
                          input(type="hidden" name=`heroSlides[${index}][imageUrl]` value=slide.imageUrl)
                          input.slide-file-input(type="file" name=`heroSlides_image_${index}` id=`slide_file_${index}` accept="image/*" onchange="previewSlideImage(this)")
                          label.slide-file-label(for=`slide_file_${index}`)
                            svg(xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor")
                              path(d="M10.75 4.75a.75.75 0 00-1.5 0v4.5h-4.5a.75.75 0 000 1.5h4.5v4.5a.75.75 0 001.5 0v-4.5h4.5a.75.75 0 000-1.5h-4.5v-4.5z")
                            | Chọn ảnh khác
                      .slide-fields-section
                        .field-row
                          .field
                            label.field__label Nhãn slide
                            .field__control
                              input.field__input(type="text" name=`heroSlides[${index}][label]` value=slide.label placeholder="Ví dụ: Khuyến mãi đặc biệt")
                          .field
                            label.field__label Giảm giá
                            .field__control
                              input.field__input(type="text" name=`heroSlides[${index}][discount]` value=slide.discount placeholder="Ví dụ: Giảm đến 20%")
                        .field
                          label.field__label Tiêu đề slide
                          .field__control
                            input.field__input(type="text" name=`heroSlides[${index}][heading]` value=slide.heading placeholder="Ví dụ: iPhone 15 Pro Max")
                        .field
                          label.field__label Mô tả phụ
                          .field__control
                            textarea.field__input.field__input--textarea(name=`heroSlides[${index}][subheading]` rows="2" placeholder="Ví dụ: Mô tả ngắn về sản phẩm...")= slide.subheading
                        .field-row
                          .field
                            label.field__label Chữ trên nút CTA
                            .field__control
                              input.field__input(type="text" name=`heroSlides[${index}][ctaText]` value=slide.ctaText placeholder="Ví dụ: Mua ngay")
                          .field
                            label.field__label Đường dẫn CTA
                            .field__control
                              input.field__input(type="text" name=`heroSlides[${index}][ctaLink]` value=slide.ctaLink placeholder="Ví dụ: /products/iphone-15")

            .add-slide-btn-container
              button.btn.btn--secondary#addSlideBtn(type="button")
                svg(xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor")
                  path(d="M10.75 4.75a.75.75 0 00-1.5 0v4.5h-4.5a.75.75 0 000 1.5h4.5v4.5a.75.75 0 001.5 0v-4.5h4.5a.75.75 0 000-1.5h-4.5v-4.5z")
                | Thêm slide mới

          .field
            label.field__label(for="heroTransitionDuration") Thời gian chuyển ảnh (giây)
            .field__control
              input.field__input(
                type="number"
                id="heroTransitionDuration"
                name="heroTransitionDuration"
                min="1"
                max="60"
                step="1"
                value=settings.heroTransitionDuration || 5
                placeholder="5"
              )
            p.field__hint Khoảng thời gian tự động chuyển sang ảnh tiếp theo

      //- ── NHÓM 4: CÀI ĐẶT FLASH SALE ─────────────────────────
      .settings-section
        .settings-section__label
          span.settings-section__number 04
          h2.settings-section__title Cài đặt Flash Sale
          p.settings-section__desc Cấu hình chương trình Khuyến mãi chớp nhoáng

        .settings-section__fields
          .field
            label.field__label Trạng thái hoạt động
            .toggle-group
              label.toggle
                input.toggle__input(
                  type="checkbox"
                  name="flashSaleEnabled"
                  id="flashSaleEnabled"
                  checked=settings.flashSaleEnabled
                )
                span.toggle__track
                span.toggle__label Kích hoạt Flash Sale
            p.field__hint Khi tắt, khung Flash Sale trên trang chủ sẽ bị ẩn hoàn toàn

          .field-row
            .field
              label.field__label(for="flashSaleStartTime") Thời gian bắt đầu
              .field__control
                input.field__input(
                  type="datetime-local"
                  id="flashSaleStartTime"
                  name="flashSaleStartTime"
                  value=settings.flashSaleStartTimeFormatted
                )
              p.field__hint Chọn thời điểm bắt đầu tự động mở Flash Sale

            .field
              label.field__label(for="flashSaleEndTime") Thời gian kết thúc
              .field__control
                input.field__input(
                  type="datetime-local"
                  id="flashSaleEndTime"
                  name="flashSaleEndTime"
                  value=settings.flashSaleEndTimeFormatted
                )
              p.field__hint Đặt mốc thời gian đếm ngược kết thúc chương trình

          .field
            label.field__label Chọn sản phẩm tham gia Flash Sale
            .products-select-box
              .products-select-box__search
                svg(xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor")
                  path(fill-rule="evenodd" d="M9 3.5a5.5 5.5 0 100 11 5.5 5.5 0 000-11zM2 9a7 7 0 1112.452 4.391l3.328 3.329a.75.75 0 11-1.06 1.06l-3.329-3.328A7 7 0 012 9z" clip-rule="evenodd")
                input.search-products-input#flashSaleProductSearch(type="text" placeholder="Tìm nhanh sản phẩm theo tên...")
              .products-list#flashSaleProductsList
                if products && products.length > 0
                  each prod in products
                    - var isChecked = settings.flashSaleProductIds && settings.flashSaleProductIds.some(id => id.toString() === prod._id.toString())
                    label.product-select-item(data-title=prod.title.toLowerCase())
                      input(
                        type="checkbox"
                        name="flashSaleProductIds[]"
                        value=prod._id.toString()
                        checked=isChecked
                      )
                      span.product-select-item__name= prod.title
                else
                  .products-list__empty Không tìm thấy sản phẩm nào
            p.field__hint Chỉ những sản phẩm được chọn mới xuất hiện tại mục Flash Sale

      //- ── NHÓM 5: LIÊN HỆ & ĐỊA CHỈ ────────────────────────────────
      .settings-section
        .settings-section__label
          span.settings-section__number 05
          h2.settings-section__title Thông tin liên hệ
          p.settings-section__desc Địa chỉ, số điện thoại, email — hiển thị trên footer & trang liên hệ

        .settings-section__fields
          .field
            label.field__label(for="address") Địa chỉ cửa hàng
            .field__control
              textarea.field__input.field__input--textarea(
                id="address"
                name="address"
                rows="2"
                placeholder="Ví dụ: 123 Nguyễn Huệ, Quận 1, TP. Hồ Chí Minh"
              )= settings.address

          .field-row
            .field
              label.field__label(for="phone") Số điện thoại
              .field__control
                input.field__input(
                  type="tel"
                  id="phone"
                  name="phone"
                  value=settings.phone
                  placeholder="0901 234 567"
                )

            .field
              label.field__label(for="email") Email liên hệ
              .field__control
                input.field__input(
                  type="email"
                  id="email"
                  name="email"
                  value=settings.email
                  placeholder="contact@example.com"
                )

          .field
            label.field__label(for="googleMapEmbed") Google Maps (mã nhúng)
            .field__control
              textarea.field__input.field__input--textarea(
                id="googleMapEmbed"
                name="googleMapEmbed"
                rows="3"
                placeholder='<iframe src="https://www.google.com/maps/embed?..." ...></iframe>'
              )= settings.googleMapEmbed
            p.field__hint Dán mã iframe từ Google Maps

          .field
            label.field__label(for="workingHours") Giờ làm việc
            .field__control
              input.field__input(
                type="text"
                id="workingHours"
                name="workingHours"
                value=settings.workingHours
                placeholder="Ví dụ: T2 – T7: 8:00 – 20:00 | CN: 9:00 – 17:00"
              )

      //- ── NHÓM 6: MẠNG XÃ HỘI ───────────────────────────────────────
      .settings-section
        .settings-section__label
          span.settings-section__number 06
          h2.settings-section__title Mạng xã hội
          p.settings-section__desc Đường dẫn đến các trang mạng xã hội của thương hiệu

        .settings-section__fields
          each platform in ['Facebook', 'Instagram', 'Zalo', 'TikTok', 'YouTube']
            .field
              label.field__label(for=`social${platform}`) #{platform}
              .field__control.field__control--icon
                span.field__icon
                  svg(xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor")
                    circle(cx="10" cy="10" r="8" fill="none" stroke="currentColor" stroke-width="1.5")
                    path(d="M10 6v8M6 10h8")
                input.field__input(
                  type="url"
                  id=`social${platform}`
                  name=`social${platform}`
                  value=settings[`social${platform}`]
                  placeholder=`https://www.${platform.toLowerCase()}.com/yourpage`
                )

      //- ── NHÓM 7: THANH TOÁN ─────────────────────────────────────────
      .settings-section
        .settings-section__label
          span.settings-section__number 07
          h2.settings-section__title Thanh toan
          p.settings-section__desc Cau hinh thoi gian giu phien thanh toan truoc khi he thong tu choi tao hoac xac nhan don

        .settings-section__fields
          .field
            label.field__label(for="onlinePaymentTimeoutMinutes") Thoi gian thanh toan (phut)
            .field__control
              input.field__input(
                type="number"
                id="onlinePaymentTimeoutMinutes"
                name="onlinePaymentTimeoutMinutes"
                min="1"
                max="180"
                step="1"
                value=settings.onlinePaymentTimeoutMinutes || 15
                placeholder="15"
              )
            p.field__hint Ap dung cho phien checkout va han thanh toan online VNPay

      .settings-actions
        .settings-actions__left
          span.settings-actions__saved#savedIndicator
            svg(xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor")
              path(fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" clip-rule="evenodd")
            | Đã lưu

        .settings-actions__right
          button.btn.btn--ghost(type="button" onclick="history.back()") Huỷ
          button.btn.btn--primary(type="submit")
            svg(xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor")
              path(d="M10.75 2.75a.75.75 0 00-1.5 0v8.614L6.295 8.235a.75.75 0 10-1.09 1.03l4.25 4.5a.75.75 0 001.09 0l4.25-4.5a.75.75 0 00-1.09-1.03l-2.955 3.129V2.75z")
            | Lưu thay đổi

  script.
    // Tự động sắp xếp lại tên trường và nhãn slide sau khi thêm/xóa
    function reindexSlides() {
      const cards = document.querySelectorAll('.hero-slide-editor-card');
      cards.forEach((card, index) => {
        card.querySelector('.slide-number').textContent = index + 1;
        card.querySelectorAll('[name]').forEach(input => {
          const name = input.getAttribute('name');
          if (name) {
            const updatedName = name.replace(/heroSlides\[\d+\]/, `heroSlides[${index}]`)
                                    .replace(/heroSlides_image_\d+/, `heroSlides_image_${index}`);
            input.setAttribute('name', updatedName);
          }
        });
        
        const fileInput = card.querySelector('input.slide-file-input');
        if (fileInput) {
          fileInput.setAttribute('id', `slide_file_${index}`);
          fileInput.setAttribute('name', `heroSlides_image_${index}`);
          const label = card.querySelector('label.slide-file-label');
          if (label) {
            label.setAttribute('for', `slide_file_${index}`);
          }
        }
      });
    }

    function deleteSlideCard(button) {
      const card = button.closest('.hero-slide-editor-card');
      if (card) {
        card.remove();
        reindexSlides();
      }
    }

    function previewSlideImage(input) {
      const card = input.closest('.hero-slide-editor-card');
      const preview = card.querySelector('.slide-image-preview');
      const file = input.files[0];
      if (file && preview) {
        const reader = new FileReader();
        reader.onload = function(e) {
          preview.innerHTML = `<img src="${e.target.result}" alt="Preview" />`;
        };
        reader.readAsDataURL(file);
      }
    }

    // Logic thêm slide động
    const addSlideBtn = document.getElementById('addSlideBtn');
    const heroSlidesList = document.getElementById('heroSlidesList');
    if (addSlideBtn && heroSlidesList) {
      addSlideBtn.addEventListener('click', function() {
        const nextIndex = heroSlidesList.querySelectorAll('.hero-slide-editor-card').length;
        const card = document.createElement('div');
        card.className = 'hero-slide-editor-card';
        card.setAttribute('data-index', nextIndex);
        card.innerHTML = `
          <div class="slide-card-header">
            <h3 class="slide-card-title">Slide #<span class="slide-number">${nextIndex + 1}</span> <span class="badge badge-new" style="background-color: var(--s-success); color: white; padding: 2px 6px; border-radius: 4px; font-size: 10px;">Mới</span></h3>
            <button class="btn-delete-slide" type="button" onclick="deleteSlideCard(this)">Xóa slide</button>
          </div>
          <div class="slide-card-body">
            <div class="slide-image-section">
              <div class="slide-image-preview">
                <div class="no-image">Chưa chọn ảnh</div>
              </div>
              <div class="slide-image-upload">
                <input type="hidden" name="heroSlides[${nextIndex}][imageUrl]" value="" />
                <input class="slide-file-input" type="file" name="heroSlides_image_${nextIndex}" id="slide_file_${nextIndex}" accept="image/*" onchange="previewSlideImage(this)" />
                <label class="slide-file-label" for="slide_file_${nextIndex}">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" style="width: 14px; height: 14px;">
                    <path d="M10.75 4.75a.75.75 0 00-1.5 0v4.5h-4.5a.75.75 0 000 1.5h4.5v4.5a.75.75 0 001.5 0v-4.5h4.5a.75.75 0 000-1.5h-4.5v-4.5z" />
                  </svg>Chọn ảnh
                </label>
              </div>
            </div>
            <div class="slide-fields-section">
              <div class="field-row">
                <div class="field">
                  <label class="field__label">Nhãn slide</label>
                  <div class="field__control">
                    <input class="field__input" type="text" name="heroSlides[${nextIndex}][label]" value="Khuyến mãi đặc biệt" placeholder="Ví dụ: Khuyến mãi đặc biệt" />
                  </div>
                </div>
                <div class="field">
                  <label class="field__label">Giảm giá</label>
                  <div class="field__control">
                    <input class="field__input" type="text" name="heroSlides[${nextIndex}][discount]" value="" placeholder="Ví dụ: Giảm đến 20%" />
                  </div>
                </div>
              </div>
              <div class="field">
                <label class="field__label">Tiêu đề slide</label>
                <div class="field__control">
                  <input class="field__input" type="text" name="heroSlides[${nextIndex}][heading]" value="" placeholder="Ví dụ: iPhone 15 Pro Max" />
                </div>
              </div>
              <div class="field">
                <label class="field__label">Mô tả phụ</label>
                <div class="field__control">
                  <textarea class="field__input field__input--textarea" name="heroSlides[${nextIndex}][subheading]" rows="2" placeholder="Ví dụ: Mô tả ngắn về sản phẩm..."></textarea>
                </div>
              </div>
              <div class="field-row">
                <div class="field">
                  <label class="field__label">Chữ trên nút CTA</label>
                  <div class="field__control">
                    <input class="field__input" type="text" name="heroSlides[${nextIndex}][ctaText]" value="Mua ngay" placeholder="Ví dụ: Mua ngay" />
                  </div>
                </div>
                <div class="field">
                  <label class="field__label">Đường dẫn CTA</label>
                  <div class="field__control">
                    <input class="field__input" type="text" name="heroSlides[${nextIndex}][ctaLink]" value="/products" placeholder="Ví dụ: /products/iphone-15" />
                  </div>
                </div>
              </div>
            </div>
          </div>
        `;
        heroSlidesList.appendChild(card);
        reindexSlides();
      });
    }

    // Lọc sản phẩm Flash Sale qua ô tìm kiếm
    const fsSearch = document.getElementById('flashSaleProductSearch');
    const fsItems = document.querySelectorAll('#flashSaleProductsList .product-select-item');
    if (fsSearch) {
      fsSearch.addEventListener('input', function () {
        const keyword = this.value.toLowerCase().trim();
        fsItems.forEach(item => {
          const title = item.getAttribute('data-title') || '';
          if (title.includes(keyword)) {
            item.style.display = 'flex';
          } else {
            item.style.display = 'none';
          }
        });
      });
    }
    // Đếm ký tự meta description
    const metaTA = document.getElementById('metaDescription');
    const metaCounter = document.getElementById('metaCounter');
    if (metaTA && metaCounter) {
      metaTA.addEventListener('input', function () {
        metaCounter.textContent = this.value.length + '/160';
        metaCounter.classList.toggle('field__counter--warn', this.value.length > 140);
      });
    }

    // Chỉ báo đã lưu
    document.querySelector('.settings-form').addEventListener('submit', function () {
      const el = document.getElementById('savedIndicator');
      setTimeout(() => el && el.classList.add('visible'), 800);
      setTimeout(() => el && el.classList.remove('visible'), 3200);
    });
