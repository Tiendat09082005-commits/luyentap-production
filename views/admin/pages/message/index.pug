extends ../../layouts/default

block css
    link(rel="stylesheet", href="/admin/css/chat.css")

block script
    script(src="/admin/js/chat.socket.js")

block main
    .chat-app

        // SIDEBAR
        aside.sidebar

            .sidebar-header
                .my-avatar A
                .sidebar-actions
                    button.icon-btn(title="Menu")
                        svg(xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor")
                            circle(cx="12" cy="5" r="1.5")
                            circle(cx="12" cy="12" r="1.5")
                            circle(cx="12" cy="19" r="1.5")


            .search-box
                .search-input-wrap
                    input(type="text" placeholder="Tìm kiếm hoặc bắt đầu cuộc trò chuyện mới")

            .conv-list

                each item, index in conversations
                    .conv-item(
                      data-conversation-id=item._id
                      class=(index === 0 ? "active" : "")
                    )

                        .avatar-wrap
                            if item.user_id
                                .avatar #{item.user_id.fullName.charAt(0).toUpperCase()}
                            else
                                .avatar U
                            .avatar-online

                        .conv-info
                            .conv-top
                                if item.user_id
                                    span.conv-name #{item.user_id.fullName}
                                else
                                    span.conv-name Unknown

                                span.conv-time
                                    if item.lastMessage && item.lastMessage.createdAt
                                        | #{new Date(item.lastMessage.createdAt).toLocaleTimeString('vi-VN',{hour:'2-digit',minute:'2-digit'})}
                                    else
                                        | --

                            .conv-bottom
                                if item.lastMessage && item.lastMessage.content
                                    if item.lastMessage.sender_role === "admin"
                                        span.conv-last Bạn: #{item.lastMessage.content}
                                    else
                                        span.conv-last #{item.lastMessage.content}
                                else
                                    span.conv-last Chưa có tin nhắn

                                if item.unread_admin > 0
                                    .unread-badge #{item.unread_admin}

        // CHAT PANEL
        main.chat-panel

            if conversations.length > 0
                - const item = conversations[0]

                .chat-header
                    .avatar-wrap
                        if item.user_id
                            .avatar.chat-avatar #{item.user_id.fullName.charAt(0)}
                        else
                            .avatar.chat-avatar U
                        .avatar-online

                    .chat-header-info
                        if item.user_id
                            .chat-header-name #{item.user_id.fullName}
                        else
                            .chat-header-name Unknown

                        .chat-header-status.online Đang hoạt động

                .messages-area

                    if item.messages && item.messages.length > 0

                        - const today = new Date().toDateString()
                        - const yesterday = new Date(Date.now() - 86400000).toDateString()
                        - let lastDate = null

                        each msg in item.messages

                            - const msgDate = new Date(msg.createdAt)
                            - const msgDay = msgDate.toDateString()

                            if msgDay !== lastDate
                                .date-divider
                                    if msgDay === today
                                        span Hôm nay
                                    else if msgDay === yesterday
                                        span Hôm qua
                                    else
                                        span #{msgDate.toLocaleDateString('vi-VN')}

                            - lastDate = msgDay

                            if msg.sender_role === "admin"
                                .msg-row.me
                                    .msg-bubble
                                        | #{msg.content}
                                        .msg-time #{msgDate.toLocaleTimeString('vi-VN',{hour:'2-digit',minute:'2-digit'})}

                            else
                                .msg-row.them
                                    .msg-bubble
                                        | #{msg.content}
                                        .msg-time #{msgDate.toLocaleTimeString('vi-VN',{hour:'2-digit',minute:'2-digit'})}

                    else
                        .empty-chat
                            span Chưa có tin nhắn

                .chat-input-bar
                    .input-actions
                        button.icon-btn#emojiBtn(title="Emoji") 😊

                        button.icon-btn(title="Đính kèm") 📎

                    emoji-picker#emojiPicker(style="display:none; position:absolute; bottom:60px;")

                    .input-wrap
                        input#inputChatAdmin(type="text" placeholder="Nhập tin nhắn")

                    button.send-btn(title="Gửi") ➤
