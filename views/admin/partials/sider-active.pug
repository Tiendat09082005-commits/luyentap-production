link(rel="stylesheet" href="https://cdn.jsdelivr.net/npm/remixicon@3.5.0/fonts/remixicon.css")

-
  const isActive = (path, exact = false, excludePaths = []) => {
    const currentPathOnly = currentUrl ? currentUrl.split('?')[0].split('#')[0] : "";
    if (exact) {
      return currentPathOnly === path;
    }
    const isMatch = currentPathOnly === path || currentPathOnly.startsWith(path + "/");
    if (!isMatch) return false;

    for (const exclude of excludePaths) {
      if (currentPathOnly === exclude || currentPathOnly.startsWith(exclude + "/")) {
        return false;
      }
    }
    return true;
  }

.sider
  .inner-menu
    ul
      li(class=isActive(`${prefixAdmin}/dashboard`) ? "active" : "")
        a(href=`${prefixAdmin}/dashboard`)
          i.ri-layout-grid-line
          span Tổng quan
      if(roles.permissions.includes("products_view"))
