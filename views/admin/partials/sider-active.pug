  const isActive = (path, exact = false, excludePaths = []) => {
    const currentPathOnly = currentUrl ? currentUrl.split('?')[0].split('#')[0] : "";
    if (exact) {
      return currentPathOnly === path;
    }
    const isMatch = currentPathOnly === path || currentPathOnly.startsWith(path + "/");
    if (!isMatch) return false;

    for (const exclude of excludePaths) {
      if (currentPathOnly === exclude || currentPathOnly.startsWith(exclude + "/")) {
        return false;
      }
    }
    return true;
  }

.sider
  .inner-menu
    //- ==============================
    //- MAIN
    //- ==============================
    ul
      li(class=isActive(`${prefixAdmin}/dashboard`) ? "active" : "")
        a(href=`${prefixAdmin}/dashboard`)
          i.ri-layout-grid-line
          span Tổng quan

    //- ==============================
    //- CỬA HÀNG
    //- ==============================
    if(roles.permissions.includes("orders_view") || roles.permissions.includes("messages_support")) 
      .menu-label Giao dịch & Tương tác
      ul
        if(roles.permissions.includes("orders_view"))
          li(class=isActive(`${prefixAdmin}/order`) ? "active" : "")
            a(href=`${prefixAdmin}/order`)
              i.ri-shopping-cart-2-line
              span Quản lý đơn hàng
        if(roles.permissions.includes("messages_support"))
          li(class=isActive(`${prefixAdmin}/messages`) ? "active" : "")
            a(href=`${prefixAdmin}/messages`)
              i.ri-message-3-line
              span Hỗ trợ chat

    //- ==============================
    //- SẢN PHẨM
    //- ==============================
    if(roles.permissions.includes("products_view") || roles.permissions.includes("products-category_view") || roles.permissions.includes("brands_view") || roles.permissions.includes("attributes_view"))
      .menu-label Quản lý kho hàng
      ul
        if(roles.permissions.includes("products_view"))
          li(class=isActive(`${prefixAdmin}/products`) ? "active" : "")
            a(href=`${prefixAdmin}/products`)
              i.ri-box-3-line
              span Danh sách sản phẩm
        if(roles.permissions.includes("products-category_view"))
          li(class=isActive(`${prefixAdmin}/products-category`) ? "active" : "")
            a(href=`${prefixAdmin}/products-category`)
              i.ri-price-tag-3-line
              span Danh mục sản phẩm
        if(roles.permissions.includes("brands_view"))
          li(class=isActive(`${prefixAdmin}/brands`) ? "active" : "")
            a(href=`${prefixAdmin}/brands`)
              i.ri-award-line
              span Thương hiệu
        if(roles.permissions.includes("attributes_view"))
          li(class=isActive(`${prefixAdmin}/attribute`) ? "active" : "")
            a(href=`${prefixAdmin}/attribute`)
              i.ri-list-settings-line
              span Thuộc tính sản phẩm

    //- ==============================
    //- HỆ THỐNG
    //- ==============================
    if(roles.permissions.includes("account_view") || roles.permissions.includes("roles_view") || roles.permissions.includes("roles_permissions") || roles.permissions.includes("settings_view"))
      // Note: setting doesnt have explicit permission check in original code
      .menu-label Hệ thống
      ul
        if(roles.permissions.includes("account_view"))
          li(class=isActive(`${prefixAdmin}/accounts/user`) ? "active" : "")
            a(href=`${prefixAdmin}/accounts/user`)
              i.ri-group-line
              span Người dùng (Khách hàng)
          li(class=isActive(`${prefixAdmin}/accounts`, false, [`${prefixAdmin}/accounts/user`]) ? "active" : "")
            a(href=`${prefixAdmin}/accounts`)
              i.ri-user-settings-line
              span Quản trị viên
        if(roles.permissions.includes("roles_view"))
          li(class=isActive(`${prefixAdmin}/roles`, false, [`${prefixAdmin}/roles/permission`]) ? "active" : "")
            a(href=`${prefixAdmin}/roles`)
              i.ri-shield-user-line
              span Nhóm quyền
        if(roles.permissions.includes("roles_permissions"))
          li(class=isActive(`${prefixAdmin}/roles/permission`) ? "active" : "")
            a(href=`${prefixAdmin}/roles/permission`)
              i.ri-lock-2-line
              span Phân quyền
        if(roles.permissions.includes("settings_view"))
          li(class=isActive(`${prefixAdmin}/setting`) ? "active" : "")
            a(href=`${prefixAdmin}/setting`)
              i.ri-settings-3-line
              span Cài đặt chung
