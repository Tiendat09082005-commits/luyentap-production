include ../../mixins/category-icon.pug

mixin categoryRow(item, level)
  - const currentThumbnail = item.thumbnail || ""
  .tree-row(
    class="tree-row--level-" + level
    data-id=item._id
    data-parent-id=item.parent_id || ""
    data-level=level
    data-icon=item.icon || defaultCategoryIcon
    data-thumbnail=currentThumbnail
    style=(level > 1 ? "display: none" : "")
  )
    if item.children && item.children.length
      button.tree-toggle.is-collapsed(data-has-children='true')
        svg(xmlns='http://www.w3.org/2000/svg' width='14' height='14' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2')
          polyline(points='9 6 15 12 9 18')
    else
      button.tree-toggle.tree-toggle--no-children(disabled)
        svg(xmlns='http://www.w3.org/2000/svg' width='14' height='14' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2')
          polyline(points='9 6 15 12 9 18')

    .tree-item
      .tree-item__thumb
        if level === 1
          +categoryIcon(item.icon, "tree-item__icon")
        else if currentThumbnail
          img.tree-item__thumb-image(src=currentThumbnail alt=item.title)
        else
          span.tree-item__thumb-placeholder No img

      .tree-item__info
        .tree-item__name
          span= item.title

          if item.status == "active"
            span.badge.badge--active Hoat dong
          else
            span.badge.badge--hidden An

          span.badge.badge--level Cap #{level}

        span.tree-item__slug /#{item.slug}

    .tree-actions
      if level < 3
        button.tree-action-btn.tree-action-btn--add(title='Them danh muc con')
          svg(xmlns='http://www.w3.org/2000/svg' width='15' height='15' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2')
            line(x1='12' y1='5' x2='12' y2='19')
            line(x1='5' y1='12' x2='19' y2='12')

      button.tree-action-btn.tree-action-btn--edit(
        title='Chinh sua'
        data-id=item._id
        data-title=item.title
        data-slug=item.slug
        data-parent-id=item.parent_id || ""
        data-status=item.status
        data-icon=item.icon || defaultCategoryIcon
        data-thumbnail=currentThumbnail
      )
        svg(xmlns='http://www.w3.org/2000/svg' width='15' height='15' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2')
          path(d='M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7')
          path(d='M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z')

      button.tree-action-btn.tree-action-btn--delete(title='Xoa')
        svg(xmlns='http://www.w3.org/2000/svg' width='15' height='15' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2')
          polyline(points='3 6 5 6 21 6')
          path(d='M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6')
          path(d='M10 11v6')
          path(d='M14 11v6')

  if item.children && item.children.length
    each child in item.children
      +categoryRow(child, level + 1)

mixin selectTree(items, level)
  each item in items
    - const prefix = '-- '.repeat(level - 1)
    option(value=item._id data-level=level) #{prefix}#{item.title}
    if item.children && item.children.length
      +selectTree(item.children, level + 1)
