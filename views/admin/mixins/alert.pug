mixin alert-success(time)
    - if (messages.thanhcong)
        .message.info
            div(
                class = "alert alert-success"
                data-time = time
                show-alert
            )
                i(class="fa-solid fa-circle-check")
                span #{messages.thanhcong}
                span(close-alert) &times;

